default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Creates an isolated keychain so signing artifacts don't persist across runs
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY"),
      is_key_content_base64: true
    )

    import_certificate(
      certificate_path: ENV.fetch("CERTIFICATE_PATH"),
      certificate_password: ENV.fetch("CERTIFICATES_P12_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ""
    )

    # Downloads the App Store distribution profile into
    # ~/Library/MobileDevice/Provisioning Profiles/ and sets SIGH_* lane context
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "ch.mants.simpletodoapp"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      profile_name: lane_context[SharedValues::SIGH_PROFILE_NAME],
      code_sign_identity: "Apple Distribution"
    )

    set_info_plist_value(
      path: "App/Info.plist",
      key: "CFBundleVersion",
      value: ENV.fetch("GITHUB_RUN_NUMBER", "1")
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        provisioningProfiles: {
          "ch.mants.simpletodoapp" => lane_context[SharedValues::SIGH_PROFILE_NAME]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
