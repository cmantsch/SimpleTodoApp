default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # Creates an isolated keychain so signing artifacts don't persist across runs
    setup_ci if ENV["CI"]

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_KEY"),
      is_key_content_base64: true
    )

    import_certificate(
      certificate_path: ENV.fetch("CERTIFICATE_PATH"),
      certificate_password: ENV.fetch("CERTIFICATES_P12_PASSWORD"),
      keychain_name: "fastlane_tmp_keychain",
      keychain_password: ""
    )

    # Downloads the App Store distribution profile into
    # ~/Library/MobileDevice/Provisioning Profiles/ and sets ENV["SIGH_NAME"]
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "ch.mants.simpletodoapp"
    )

    set_info_plist_value(
      path: "App/Info.plist",
      key: "CFBundleVersion",
      value: ENV.fetch("GITHUB_RUN_NUMBER", "1")
    )

    build_app(
      project: "App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      # PROVISIONING_PROFILE + CODE_SIGN_IDENTITY apply to the archive step;
      # export_options applies to the export step — both are needed.
      xcargs: "CODE_SIGN_STYLE=Manual DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')} PROVISIONING_PROFILE=#{ENV['SIGH_UUID']} CODE_SIGN_IDENTITY='Apple Distribution'",
      export_options: {
        teamID: ENV.fetch("APPLE_TEAM_ID"),
        signingStyle: "manual",
        provisioningProfiles: {
          "ch.mants.simpletodoapp" => ENV["SIGH_NAME"]
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
